<?xml version="1.0"?>
<robot name="mon_bras">

    <!-- BASE -->
    <link name="base">
        <visual>
            <geometry>
                <box size="0.1 0.1 0.05"/>
            </geometry>
        </visual>
    </link>

    <!-- LIEN 1 -->
    <link name="lien1">
        <visual>
            <geometry>
                <cylinder radius="0.03" length="0.15"/>
            </geometry>
        </visual>
    </link>

    <joint name="joint1" type="revolute">
        <parent link="base"/>
        <child link="lien1"/>
        <origin xyz="0 0 0.1"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
    </joint>

    <!-- LIEN 2 -->
    <link name="lien2">
        <visual>
            <geometry>
                <cylinder radius="0.025" length="0.15"/>
            </geometry>
        </visual>
    </link>

    <joint name="joint2" type="revolute">
        <parent link="lien1"/>
        <child link="lien2"/>
        <origin xyz="0 0 0.15"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
    </joint>

    <!-- LIEN 3 -->
    <link name="lien3">
        <visual>
            <geometry>
                <cylinder radius="0.02" length="0.12"/>
            </geometry>
        </visual>
    </link>

    <joint name="joint3" type="revolute">
        <parent link="lien2"/>
        <child link="lien3"/>
        <origin xyz="0 0 0.15"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
    </joint>

    <!-- LIEN 4 -->
    <link name="lien4">
        <visual>
            <geometry>
                <cylinder radius="0.018" length="0.1"/>
            </geometry>
        </visual>
    </link>

    <joint name="joint4" type="revolute">
        <parent link="lien3"/>
        <child link="lien4"/>
        <origin xyz="0 0 0.12"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
    </joint>

    <!-- LIEN 5 -->
    <link name="lien5">
        <visual>
            <geometry>
                <cylinder radius="0.015" length="0.08"/>
            </geometry>
        </visual>
    </link>

    <joint name="joint5" type="revolute">
        <parent link="lien4"/>
        <child link="lien5"/>
        <origin xyz="0 0 0.1"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
    </joint>

    <!-- LIEN 6 — effecteur -->
    <link name="lien6">
        <visual>
            <geometry>
                <box size="0.05 0.05 0.02"/>
            </geometry>
        </visual>
    </link>

    <joint name="joint6" type="revolute">
        <parent link="lien5"/>
        <child link="lien6"/>
        <origin xyz="0 0 0.08"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
    </joint>

</robot>